# Supabase: Project Settings → Database → URI (use "Transaction" pooler or direct 5432 for migrations)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Set to false only for local Postgres without SSL
# DATABASE_SSL=false

# openssl rand -base64 32 (or similar); must be >= 32 chars
JWT_SECRET=

# Comma-separated browser origins (Vercel preview + prod)
FRONTEND_ORIGINS=http://localhost:5173

PORT=5000
